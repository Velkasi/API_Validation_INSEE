# Exemples de variables d'environnement nécessaires pour les validateurs
# Remplissez les valeurs réelles dans un fichier `.env` non tracké

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

LMSTUDIO_BASE_URL=http://192.168.1.167:1234/v1
VLM_MODEL=qwen/qwen3-vl-4b (possible de prendre plus petit modèle si besoin)

# AZURE_API_KEY=
# AZURE_REGION=

# GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json
# GOOGLE_API_KEY=

SUPABASE_URL=
# Server-side scripts need a service role key if RLS is enabled on the tables.
# Use the SUPABASE_SERVICE_ROLE_KEY only on trusted backend code, never in a browser.
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

INSEE_API_KEY=


# SENTRY_DSN=
